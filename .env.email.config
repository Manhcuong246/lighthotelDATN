# ==========================================
# EMAIL CONFIGURATION FOR LIGHT HOTEL
# ==========================================
# Add these settings to your .env file

# Option 1: Gmail SMTP (Recommended for testing)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Option 2: Mailtrap (for testing - no real emails sent)
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password
# MAIL_ENCRYPTION=null
# MAIL_FROM_ADDRESS=booking@lighthotel.com
# MAIL_FROM_NAME="${APP_NAME}"

# Option 3: SendGrid (for production)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=booking@lighthotel.com
# MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# HOW TO SETUP GMAIL APP PASSWORD:
# ==========================================
# 1. Go to https://myaccount.google.com/
# 2. Security → 2-Step Verification (must be enabled)
# 3. App passwords → Generate new app password
# 4. Select "Mail" and device type
# 5. Copy the 16-character password to MAIL_PASSWORD

# ==========================================
# QUEUE CONFIGURATION (optional but recommended)
# ==========================================
# Use database queue for async email sending
# QUEUE_CONNECTION=database

# Run these commands after configuration:
# php artisan config:clear
# php artisan queue:table (if using database queue)
# php artisan migrate (to create queue table)
