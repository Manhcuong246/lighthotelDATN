# ============================================
# Light Hotel Booking System - Environment Configuration
# ============================================
# Copy: copy .env.example .env  (Unix: cp .env.example .env)
# Mặc định: chạy local (HTTP), không tunnel / không reverse proxy.
# ============================================

# Application Settings
APP_NAME="Light Hotel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Không có dấu / cuối. Docker nginx: khớp cổng map (APP_PORT), vd. http://127.0.0.1:8080
# Artisan (không Docker): php artisan serve --host=127.0.0.1 --port=8000 → APP_URL=http://127.0.0.1:8000
APP_URL=http://127.0.0.1:8080

# Cổng nginx khi chạy docker compose (map vào 80 trong container)
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
# Chạy PHP trên máy, MySQL trong Docker: DB_HOST=127.0.0.1, DB_PORT = cổng forward DB_PORT_FORWARD (vd. 3307).
# Chạy Laravel trong Docker (compose): DB_HOST=mysql, DB_PORT=3306.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Map host:container — đổi 3307 nếu máy bạn đã có MySQL ở 3306
DB_PORT_FORWARD=3307
DB_DATABASE=hotel_booking
DB_USERNAME=root
DB_PASSWORD=
# Chỉ dùng với docker-compose (MySQL image init / root trong container)
DB_ROOT_PASSWORD=root_password
# Đặt trùng DB_PASSWORD khi dùng Docker user `app` (compose đọc biến này cho MYSQL_PASSWORD).
LARAVEL_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Local HTTP: để trống TRUSTED_PROXIES, SESSION_SECURE_COOKIE=false.
# Chỉ khi có HTTPS phía trước (reverse proxy): TRUSTED_PROXIES=* và SESSION_SECURE_COOKIE=true
# TRUSTED_PROXIES=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Thư mục con trong storage/app/public — ảnh phòng: /storage/{ROOM_IMAGES_DIRECTORY}/...
ROOM_IMAGES_DIRECTORY=room_images

# Mail — local: ghi vào storage/logs (không gửi SMTP). Đổi smtp khi cần gửi thật.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=database

CACHE_STORE=null
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ollama (AI Chat)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Gemini (AI Chat — gọi API Google; để trống nếu chỉ dùng Ollama/local)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# VNPay — để trống TMN + HASH = không dùng cổng (đặt phòng chọn tiền mặt / CK). Có key thì vẫn gọi sandbox/production.
# vnp_ReturnUrl = {APP_URL}/payment/vnpay/return (APP_URL phải khớp URL đăng ký merchant nếu test VNPay).
# php artisan vnpay:doctor
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_SERVER_IP=127.0.0.1
VNPAY_PAY_ENTRY_TTL_DAYS=14
VNPAY_TXN_EXPIRE_MINUTES=15

# PhpMyAdmin — http://127.0.0.1:PMA_PORT (docker compose up)
PMA_PORT=8081

# --- Tùy chọn: tunnel công khai (HTTPS) — không cần cho chạy local thuần ---
# Scripts: scripts/ngrok-auto.ps1, ngrok-http.ps1, ngrok-local.ps1 | Mẫu: ngrok.example.yml
# PAYMENT_MAIL_HERO_URL= (ảnh hero email; URL https đầy đủ hoặc để trống)
