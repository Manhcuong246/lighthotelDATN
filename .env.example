# ============================================
# Light Hotel Booking System - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# Command: cp .env.example .env   (Windows: copy .env.example .env)
# ============================================

# Application Settings
APP_NAME="Light Hotel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Không có dấu / cuối. Docker: khớp cổng nginx (APP_PORT). Artisan: http://127.0.0.1:8000
APP_URL=http://127.0.0.1:8000
#
# --- Ngrok / tunnel công khai (HTTPS) ---
# Tự động một lệnh (đọc APP_PORT, .env, Docker):  .\scripts\ngrok-auto.ps1
# Về local:  .\scripts\ngrok-local.ps1
# Docker: để APP_PORT khớp nginx, chạy compose; tay: .\scripts\ngrok-http.ps1 | hoặc copy ngrok.example.yml → ngrok.project.yml → ngrok start lighthotel --config ngrok.project.yml
# Artisan (không Docker): php artisan serve --host=127.0.0.1 --port=8000  rồi  ngrok http 8000
# Copy URL https HTTPS mà ngrok in ra (vd. https://xxxx.ngrok-free.app), KHÔNG có / cuối → APP_URL
# Bật tin cậy proxy + cookie an toàn cho HTTPS:
# TRUSTED_PROXIES=*
# SESSION_SECURE_COOKIE=true
# Sau đó: php artisan config:clear
# VNPay Return URL trong sandbox phải khớp: {APP_URL}/payment/vnpay/return
# Ảnh hero email thanh toán (URL đầy đủ https://...). Để trống = ảnh mặc định trong code.
# PAYMENT_MAIL_HERO_URL=

# Cổng nginx khi chạy docker compose (map vào 80 trong container)
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
# Chạy PHP trên máy, MySQL trong Docker: DB_HOST=127.0.0.1, DB_PORT = cổng forward (vd. 3307).
# Chạy Laravel trong Docker (compose): DB_HOST=mysql, DB_PORT=3306.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_PORT_FORWARD=3306
DB_DATABASE=hotel_booking
DB_USERNAME=root
DB_PASSWORD=
# Chỉ dùng với docker-compose (MySQL image init / root trong container)
DB_ROOT_PASSWORD=root_password
# Đặt trùng DB_PASSWORD khi dùng Docker user `app` (compose đọc biến này cho MYSQL_PASSWORD).
LARAVEL_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Reverse proxy / HTTPS phía trước: Ngrok / nginx SSL → TRUSTED_PROXIES=*
# TRUSTED_PROXIES=
# true khi APP_URL là https://... (Ngrok); false cho http://127.0.0.1 local thuần
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Thư mục con trong storage/app/public — ảnh phòng: /storage/{ROOM_IMAGES_DIRECTORY}/...
ROOM_IMAGES_DIRECTORY=room_images

# Mail (Gmail: bật 2FA → App Password). Sau đổi: php artisan config:clear
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=database

CACHE_STORE=null
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ollama (AI Chat)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Gemini (AI Chat - ưu tiên nếu có)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# VNPay sandbox — vnp_ReturnUrl = {APP_URL}/payment/vnpay/return (APP_URL phải khớp URL merchant đăng ký; test từ mạng ngoài cần HTTPS công khai)
# Trên cổng merchant sandbox, whitelist Return URL nếu portal yêu cầu
# Kiểm tra nhanh: php artisan vnpay:doctor
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# IP fallback khi không lấy được IP khách (gọi nội bộ). Sau reverse proxy có thể cần TRUSTED_PROXIES để lấy IP thật
VNPAY_SERVER_IP=127.0.0.1
VNPAY_PAY_ENTRY_TTL_DAYS=14
VNPAY_TXN_EXPIRE_MINUTES=15

# PhpMyAdmin — http://127.0.0.1:PMA_PORT (docker compose up)
PMA_PORT=8081
