# ============================================
# Light Hotel Booking System - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# Command: cp .env.example .env
# ============================================

# Application Settings
APP_NAME="Light Hotel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Dev: http://127.0.0.1:8000 (php artisan serve) or Docker URL (no trailing slash)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hotel_booking
DB_USERNAME=root
DB_PASSWORD=
# Nên đặt trùng DB_PASSWORD. Tránh lỗi MySQL "using password: NO" khi Windows có DB_PASSWORD rỗng trong env hệ thống (che cả .env).
LARAVEL_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Reverse proxy / HTTPS phía trước: ví dụ TRUSTED_PROXIES=* (dev local thường để trống / không khai báo)
# TRUSTED_PROXIES=
# true nếu site chỉ mở qua HTTPS; false cho http://127.0.0.1
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Thư mục con trong storage/app/public — ảnh phòng: /storage/{ROOM_IMAGES_DIRECTORY}/...
ROOM_IMAGES_DIRECTORY=room_images

# Gửi email (SMTP — ví dụ Gmail: bật 2FA + tạo App Password)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=database

CACHE_STORE=null
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ollama (AI Chat)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Gemini (AI Chat - ưu tiên nếu có)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# VNPay sandbox — vnp_ReturnUrl = {APP_URL}/payment/vnpay/return (APP_URL phải khớp URL merchant đăng ký; test từ mạng ngoài cần HTTPS công khai)
# Trên cổng merchant sandbox, whitelist Return URL nếu portal yêu cầu
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# IP fallback khi không lấy được IP khách (gọi nội bộ). Sau reverse proxy có thể cần TRUSTED_PROXIES để lấy IP thật
VNPAY_SERVER_IP=127.0.0.1
VNPAY_PAY_ENTRY_TTL_DAYS=14
VNPAY_TXN_EXPIRE_MINUTES=15
