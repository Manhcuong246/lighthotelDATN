# Chỉ dùng khi chạy `docker compose` (nginx mở cổng 8080). Chạy local PHP không dùng file này.
APP_NAME="Light Hotel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hotel_booking
DB_USERNAME=app
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password

SESSION_DRIVER=database
CACHE_STORE=null
QUEUE_CONNECTION=database
