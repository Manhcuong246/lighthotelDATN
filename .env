# Application Settings
APP_NAME="Light Hotel"
APP_ENV=local
APP_KEY=base64:Tks6J6z3yyD85mCvCihJ68fE9jEzTEd9vakkupw88t8=
APP_DEBUG=true
# Docker nginx — APP_URL khớp APP_PORT (local, không có / cuối)
APP_URL=https://19ed-2001-ee0-40c1-8036-880d-eb8-4feb-e02e.ngrok-free.app
APP_PORT=8088

# --- Ngrok (HTTPS công khai): .\scripts\ngrok-http.ps1 hoặc copy ngrok.example.yml → ngrok.project.yml → ngrok start lighthotel --config ngrok.project.yml
# Khi có URL Forwarding https://... : APP_URL=https://.... (không / cuối) | TRUSTED_PROXIES=* | SESSION_SECURE_COOKIE=true
# docker compose up -d --force-recreate app && docker compose exec app php artisan config:clear
# VNPay: Return URL = {APP_URL}/payment/vnpay/return | Quay local: APP_URL=http://127.0.0.1:8088, tắt 2 dòng proxy/cookie, recreate app, config:clear

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_PORT_FORWARD=3307
DB_DATABASE=hotel_booking
DB_USERNAME=app
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password
# Trùng DB_PASSWORD khi dùng Docker user `app` (compose đọc cho MYSQL_PASSWORD).
LARAVEL_DB_PASSWORD=app_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Local HTTP: để TRUSTED_PROXIES trống + SESSION_SECURE_COOKIE=false. Ngrok HTTPS: TRUSTED_PROXIES=* + SESSION_SECURE_COOKIE=true
TRUSTED_PROXIES=*
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Thư mục con trong storage/app/public — ảnh phòng: /storage/{ROOM_IMAGES_DIRECTORY}/...
ROOM_IMAGES_DIRECTORY=room_images

# Mail (Gmail: bật 2FA → App Password). Sau đổi: php artisan config:clear
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=leductrungxq6@gmail.com
MAIL_PASSWORD="syha ehvg uoxf tjpp"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=leductrungxq6@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=database

CACHE_STORE=null
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ollama (AI Chat)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Gemini (AI Chat - ưu tiên nếu có)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# VNPay sandbox — vnp_ReturnUrl = {APP_URL}/payment/vnpay/return (APP_URL phải khớp URL merchant đăng ký; test từ mạng ngoài cần HTTPS công khai)
# Trên cổng merchant sandbox, whitelist Return URL nếu portal yêu cầu — kiểm tra: php artisan vnpay:doctor
VNPAY_TMN_CODE=RAN82HXP
VNPAY_HASH_SECRET=4EBRZ3S70W7RVBK5RZKZBSN8T8YZYGKZ
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# IP fallback khi không lấy được IP khách (gọi nội bộ). Sau reverse proxy có thể cần TRUSTED_PROXIES để lấy IP thật
VNPAY_SERVER_IP=127.0.0.1
VNPAY_PAY_ENTRY_TTL_DAYS=14
VNPAY_TXN_EXPIRE_MINUTES=15

# PhpMyAdmin (--profile tools)
PMA_PORT=8081
